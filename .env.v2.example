NODE_ENV=production
PORT=5000
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER/VideoCompressionApp
JWT_SECRET=replace-with-at-least-32-random-bytes
V2_ACCESS_TOKEN_TTL=15m
V2_REFRESH_TOKEN_DAYS=30
REDIS_URL=redis://redis:6379
REALTIME_REDIS_ENABLED=true
EVENT_OUTBOX_MODE=worker
DESKTOP_ONLY_MODE=false
DESKTOP_CURRENT_VERSION=2.0.0
EDGE_REGISTRATION_SECRET=replace-with-random-edge-secret
EDGE_TRANSFER_SECRET=replace-with-separate-random-transfer-secret
EDGE_NODE_ID=primary-edge
EDGE_NODE_NAME=Primarni Media Edge
EDGE_SITE_ID=primary
EDGE_BASE_URL=http://media-edge.lan:5100
CONTROL_API_URL=https://vca.example.ba/api
MEDIA_STORAGE_ROOT=D:\VideoCompressionApp\storage
PREMIERE_DOWNLOAD_TICKET_TTL_MINUTES=120
S3_ENDPOINT=https://s3.example.ba
S3_BUCKET=vca-proxies
S3_ACCESS_KEY=replace
S3_SECRET_KEY=replace
