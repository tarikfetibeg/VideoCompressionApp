{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aplikacija v2",
  "version": "2.0.0",
  "identifier": "ba.tvkuca.aplikacijav2",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ../../frontend",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build --prefix ../../frontend",
    "frontendDist": "../../../frontend/dist"
  },
  "app": {
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; connect-src 'self' ipc: http://ipc.localhost https: wss:; img-src 'self' asset: http://asset.localhost blob: data: https:; media-src 'self' asset: http://asset.localhost blob: https:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    },
    "windows": [
      {
        "label": "main",
        "title": "Aplikacija v2",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "category": "Business",
    "shortDescription": "Operativni sistem za TV produkciju",
    "longDescription": "Windows desktop aplikacija za organizaciju TV produkcije, video materijala, jobova, rundowna i ispravki.",
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["vca"]
      }
    },
    "updater": {
      "endpoints": [],
      "pubkey": ""
    }
  }
}
