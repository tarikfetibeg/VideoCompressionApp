{
  "manifestVersion": 5,
  "id": "ba.tvkuca.aplikacijav2.premiere",
  "name": "Aplikacija v2 Jobs",
  "version": "2.0.0",
  "main": "index.html",
  "host": {
    "app": "premierepro",
    "minVersion": "25.6.0"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "vca-job-panel",
      "label": { "default": "Aplikacija v2 Jobs" },
      "minimumSize": { "width": 300, "height": 420 },
      "preferredDockedSize": { "width": 360, "height": 680 }
    }
  ],
  "requiredPermissions": {
    "localFileSystem": "fullAccess",
    "launchProcess": {
      "schemes": ["vca"],
      "extensions": ["", ".json", ".mp4", ".mov", ".mxf", ".wav", ".mp3"]
    }
  }
}
