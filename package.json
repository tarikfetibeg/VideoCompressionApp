{
  "name": "videocompressionapp",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "start": "node backend/app.js",
    "start:all": "node scripts/startAll.js",
    "start:dev": "cross-env NODE_ENV=development node backend/app.js",
    "start:prod": "cross-env NODE_ENV=production node backend/app.js",
    "worker:video": "node backend/workers/videoWorker.js",
    "worker:hls": "node backend/workers/hlsWorker.js",
    "worker:preview": "node backend/workers/previewMaintenanceWorker.js",
    "admin:create": "node backend/scripts/createAdmin.js",
    "indexes:create": "node backend/scripts/createIndexes.js",
    "indexes:explain": "node backend/scripts/explainIndexes.js",
    "searchtext:backfill": "node backend/scripts/backfillSearchText.js",
    "searchprefixes:backfill": "node backend/scripts/backfillSearchPrefixes.js",
    "jobs:lifecycle-backfill": "node backend/scripts/backfillEditJobLifecycle.js",
    "corrections:backfill": "node backend/scripts/backfillCorrectionRequests.js",
    "contenttypes:backfill": "node backend/scripts/backfillVideoContentTypes.js",
    "hls:benchmark": "node backend/scripts/benchmarkHls.js",
    "desktop:dev": "node scripts/startDesktopDev.js",
    "desktop:dev:client": "npm run tauri:dev --workspace @vca/desktop",
    "desktop:build": "npm run tauri:build --workspace @vca/desktop",
    "desktop:check": "npm run check --workspace @vca/desktop",
    "edge:start": "npm start --workspace @vca/media-edge",
    "event-worker:start": "node backend/workers/eventOutboxWorker.js",
    "v2:migrate": "node backend/scripts/migrateV2Foundation.js",
    "v2:migrate:dry-run": "node backend/scripts/migrateV2Foundation.js --dry-run",
    "v2:build": "npm run build --prefix frontend && npm run build --workspace @vca/contracts && npm run desktop:check",
    "heroku-postbuild": "NPM_CONFIG_PRODUCTION=false npm install --prefix frontend && npm run build --prefix frontend"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "@tus/file-store": "^1.5.1",
    "@tus/server": "^1.10.2",
    "archiver": "^7.0.1",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "dotenv-flow": "^4.1.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "ffmpeg": "^0.0.4",
    "fluent-ffmpeg": "^2.1.3",
    "jsonwebtoken": "^9.0.2",
    "jwt-decode": "^4.0.0",
    "mammoth": "^1.12.0",
    "mongoose": "^8.6.2",
    "multer": "^1.4.5-lts.1",
    "redis": "^4.7.1",
    "socket.io": "^4.8.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "cross-env": "^7.0.3"
  }
}
