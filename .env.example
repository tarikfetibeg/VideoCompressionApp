MONGODB_URI=mongodb://127.0.0.1:27017/video_compression_app
JWT_SECRET=replace_with_a_long_random_secret
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000
REDIS_URL=redis://127.0.0.1:6379

# redis = production-safe queue with separate worker; local = QA/dev queue inside the web process.
PROCESSING_QUEUE=redis

# Broadcast source uploads can be large. Increase only if local disk and network can handle it.
MAX_UPLOAD_SIZE_GB=25
MAX_UPLOAD_FILES=50

# Reporter OFF audio files attached to edit jobs.
MAX_OFF_FILE_SIZE_MB=500
MAX_OFF_FILES=12

# Reporter brief import from DOCX/TXT/MD/RTF.
MAX_BRIEF_IMPORT_SIZE_MB=25

# Optional development escape hatch. Keep disabled in production.
ALLOW_PUBLIC_REGISTRATION=false

# Used by: npm run admin:create
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password
ADMIN_RESET_PASSWORD=false
