MONGODB_URI=mongodb://127.0.0.1:27017/video_compression_app
JWT_SECRET=replace_with_a_long_random_secret
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000,http://localhost:5173,http://127.0.0.1:5173
REDIS_URL=redis://127.0.0.1:6379

# redis = production-safe queue with separate worker; local = QA/dev queue inside the web process.
PROCESSING_QUEUE=redis
# Omit for automatic behavior: local queue disables realtime Redis, redis queue enables it.
# Set explicitly to false when testing without Redis or true in a multi-instance deployment.
REALTIME_REDIS_ENABLED=
MONGOOSE_AUTO_INDEX=false

# Reusable HLS/MP4 preview ticket lifetime. Default: 120 minutes.
MEDIA_TICKET_TTL_MINUTES=120
MEDIA_TICKET_CACHE_TTL_SECONDS=15
MEDIA_TICKET_CACHE_MAX=5000
MEDIA_TICKET_USAGE_WRITE_INTERVAL_SECONDS=60

# HLS work is isolated from ingest. Keep one GPU encode active per RTX 3060.
HLS_QUEUE_CONCURRENCY=1
# Keep the previous HLS version briefly so cached media tickets finish cleanly.
HLS_PREVIOUS_VERSION_GRACE_SECONDS=30

# Broadcast source uploads can be large. Increase only if local disk and network can handle it.
MAX_UPLOAD_SIZE_GB=25
MAX_UPLOAD_FILES=50

# Reporter OFF audio files attached to edit jobs.
MAX_OFF_FILE_SIZE_MB=500
MAX_OFF_FILES=12

# Reporter brief import from DOCX/TXT/MD/RTF.
MAX_BRIEF_IMPORT_SIZE_MB=25

# Optional development escape hatch. Keep disabled in production.
ALLOW_PUBLIC_REGISTRATION=false

# Used by: npm run admin:create
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password
ADMIN_RESET_PASSWORD=false
